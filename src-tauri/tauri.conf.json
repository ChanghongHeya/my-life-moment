{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Life Moment",
  "version": "0.1.0",
  "identifier": "com.hechanghong.lifemoment",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://localhost:1420 http://127.0.0.1:1420 ws://localhost:1421 ws://127.0.0.1:1421 https:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self';"
    },
    "windows": [
      {
        "label": "main",
        "title": "Life Moment",
        "width": 380,
        "height": 600,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "transparent": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": true
      }
    ],
    "trayIcon": null
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhFRjIwNzU4NDhCNzlCMTgKUldRWW03ZElXQWZ5anBpbUtaTHhWeXZOQUVPVi9XMEYrb1FzbkxCY0s1TUtlUmFIWXBwKzFFS0cK",
      "endpoints": [
        "https://github.com/ChanghongHeya/my-life-moment/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
